# Docker Compose host paths (see docker-compose.yml).
# HARMONY_DATA_PATH=./harmony-data
# MUSIC_PATH=./music

# Optional overrides — harmony reads config.yaml in data_dir by default.
# HARMONY_DATA_DIR=~/.harmony
# Comma-separated library roots for `harmony index` and POST /v1/index (when paths omitted).
# HARMONY_INDEX_PATHS=/music
